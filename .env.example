# ---- OpenAI ----
# Used for the Realtime "patient" voice (speech-to-speech) and the bug-analysis judge.
OPENAI_API_KEY=sk-...

# Realtime model. GA model is "gpt-realtime". If your account lacks access, fall back to
# "gpt-4o-realtime-preview".
OPENAI_REALTIME_MODEL=gpt-realtime

# Voice for our patient bot (alloy, ash, ballad, coral, echo, sage, shimmer, verse).
OPENAI_REALTIME_VOICE=alloy

# Chat model used by scripts/analyze.py to draft the bug report.
OPENAI_JUDGE_MODEL=gpt-4o

# ---- Twilio ----
# Create an account, buy ONE phone number, and report that number on the submission form.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Your purchased Twilio number in E.164 (this is the single caller number for all test calls).
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ---- Target ----
# Pretty Good AI assessment line. Do not change.
PGAI_TEST_NUMBER=+18054398008

# ---- Public tunnel ----
# Host (no scheme) that Twilio can reach your local server at, e.g. from `ngrok http 8000`.
# Example: ab12-34-56-78-90.ngrok-free.app
PUBLIC_HOST=

# Port the FastAPI server listens on locally.
PORT=8000

# Safety cap on call length (seconds).
MAX_CALL_SECONDS=210
